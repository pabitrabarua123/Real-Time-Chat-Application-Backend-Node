{
  "compilerOptions": {
    "target": "ES6",
    "module": "commonjs",
    "rootDir": "./",        // ✅ current folder (server)
    "outDir": "./dist",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["./**/*"],    // ✅ include all TS files inside server
  "exclude": ["dist", "node_modules"]
}